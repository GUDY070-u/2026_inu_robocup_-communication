def make_frame(msg_type, msg_id, *data):
    body = "|".join([msg_type, str(msg_id), *map(str, data)])
    return f"@|{body}|$"


def parse_frame(frame):
    if not frame.startswith("@|") or not frame.endswith("|$"):
        raise ValueError(f"Invalid frame: {frame}")

    parts = frame[2:-2].split("|")

    return {
        "type": parts[0],
        "msg_id": parts[1],
        "data": parts[2:],
    }

